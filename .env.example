# 多模态重排服务环境配置

# ==================== 认证相关 ====================
ACCESS_TOKEN=your_access_token_here

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=6006
WORKERS=1
WORKER_CLASS=uvicorn.workers.UvicornWorker
WORKER_CONNECTIONS=100
TIMEOUT=300
KEEP_ALIVE=10

# ==================== 模型配置 ====================
# 模型路径 - 支持多模态模型 (Qwen3-VL-Reranker-2B) 或纯文本模型 (Qwen3-Reranker-4B)
MODEL_NAME_OR_PATH=./models/Qwen3-VL-Reranker-2B

# 模型类型: text (纯文本) / multimodal (多模态) / auto (自动检测)
MODEL_TYPE=multimodal

# 运行设备: cuda / cpu / auto
MODEL_DEVICE=cuda

# 模型精度: bf16 / fp16 / fp32
MODEL_PRECISION=bf16

# 最大序列长度
MAX_SEQ_LENGTH=512

# 批处理大小（多模态建议较小，如4）
BATCH_SIZE=4

# 显存使用百分比限制
MAX_MEMORY_PERCENTAGE=80

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
